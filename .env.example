# Trading212 API credentials (demo and/or live)
# Copy to .env and fill in values:  cp .env.example .env

API_KEY_DEMO=
API_SECRET_DEMO=

API_KEY_LIVE=
API_SECRET_LIVE=

# Container timezone (session strategy uses Europe/Madrid)
TZ=Europe/Madrid

# Telegram alerts (optional — can also be set from the Alerts tab in the UI)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
