{
    "name": "Session Breakout Retest",
    "ticker_API": "None",
    "ticker_data": "NQ=F",
    "interval": "15m",
    "period": "max",
    "action": "BUY",
    "entry_rule": {
        "type": "OR",
        "signals": [
            {
                "type": "session_retest_long",
                "session_hour": 15,
                "session_minute": 30,
                "breakout_deadline_hour": 16,
                "breakout_deadline_minute": 30,
                "retest_deadline_hour": 23,
                "retest_deadline_minute": 0,
                "breakout_buffer_pct": 0,
                "retest_tolerance_pct": 0,
                "win_units": 1.75,
                "loss_units": 1
            },
            {
                "type": "session_retest_short",
                "session_hour": 15,
                "session_minute": 30,
                "breakout_deadline_hour": 16,
                "breakout_deadline_minute": 30,
                "retest_deadline_hour": 23,
                "retest_deadline_minute": 0,
                "breakout_buffer_pct": 0,
                "retest_tolerance_pct": 0,
                "win_units": 1.75,
                "loss_units": 1
            }
        ]
    },
    "exit_rule": {
        "type": "OR",
        "signals": [
            {
                "type": "flatten_before_next_session",
                "flatten_hour": 14,
                "flatten_minute": 0
            },
            {
                "type": "sl_session_mid"
            },
            {
                "type": "tp_session_ratio"
            }
        ]
    }
}