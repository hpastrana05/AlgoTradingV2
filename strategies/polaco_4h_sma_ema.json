{
    "name": "Polaco 4h SMA EMA",
    "ticker_API": "None",
    "ticker_data": "EURUSD=X",
    "interval": "4h",
    "period": "max",
    "action": "BUY",
    "entry_rule": {
        "type": "AND",
        "signals": [
            {
                "type": "candle_above_sma",
                "sma_value": 9
            },
            {
                "type": "OR",
                "signals": [
                    {
                        "type": "ema_ma_cross_below",
                        "ema_value": 50,
                        "ma_value": 9
                    },
                    {
                        "type": "ema_ma_cross_above",
                        "ema_value": 50,
                        "ma_value": 9
                    }
                ]
            }
        ]
    },
    "exit_rule": {
        "type": "OR",
        "signals": [
            {
                "type": "tp_by_ratio",
                "loss_units": 1,
                "win_units": 1
            },
            {
                "type": "sl_lowest_value_last_candle"
            }
        ]
    }
}